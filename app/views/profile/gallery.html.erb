<!DOCTYPE html>

<html>
    <head>
        <title>Image Gallery</title>
        <%= stylesheet_link_tag "main" %>
    </head>
    <body>

		<header>
			<nav class="navbar navbar-dark bg-dark">
				<a class="navbar-brand"	href="<%= profile_index_url %>">WZhang</a>
				<ul class="nav nav-pills">
					<li class="nav-item">
						<a class="nav-link" href="<%= profile_index_url %>"><i class="fas fa-home"></i> Homepage </a>
					</li>
					
					<li class="nav-item">
						<a class="nav-link" href="<%= profile_portfolio_url %>"><i class="fa-solid fa-book-open"></i> Academics </a>
					</li>

					<li class="nav-item">
						<a class="nav-link" href="<%= profile_about_url %>"><i class="fa-solid fa-book-open"></i> Personal </a>
					</li>
					
					<li class="nav-item">
						<a class="nav-link active" href="<%= profile_gallery_url %>"><i class="fa-solid fa-camera"></i> Gallery </a>
					</li>
				</ul>
			</nav>
		</header>

        <div class="container">
            <div class="row">
                <div class="col" id="galleryintro">
                    This is a small collection of pictures I took using my iPhone.
                </div>
            </div>
            <div class="row">
                <div class="col-lg">
                    <%= image_tag("tall1.jpg",:class => "img-fluid")%>
                    <%= image_tag("tall2.jpg",:class => "img-fluid")%>
                </div>
                <div class="col-lg">
                    <%= image_tag("tall3.jpg",:class => "img-fluid")%>
                    <%= image_tag("tall1.jpg",:class => "img-fluid")%>
                </div>
            </div>
            <div class="row">
                <div class="col">
                    <%= image_tag("wide1.jpg",:class => "img-fluid")%>
                    <%= image_tag("wide2.jpg",:class => "img-fluid")%>
                </div>
            </div>
        </div>
    </body>
</html>